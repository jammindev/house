# FastAPI / Supabase backend configuration
PROJECT_NAME=House API
API_V1_PREFIX=/api/v1
DEBUG=false

# Supabase settings (keep these server-side only)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated

# Database connection for SQLModel (use Supabase Postgres or local Postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres

# Comma-separated origins allowed for CORS (e.g., Next.js frontend)
BACKEND_CORS_ORIGINS=http://localhost:3000
