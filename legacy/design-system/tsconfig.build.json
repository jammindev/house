{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist/types",
    "rootDir": "./src",
    "stripInternal": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.stories.*",
    "src/**/*.test.*"
  ]
}
