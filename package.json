{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config ui/vite.config.ts",
    "dev:watch": "vite build --watch --config ui/vite.config.ts",
    "build": "tsc -b ui/tsconfig.json && vite build --config ui/vite.config.ts",
    "lint": "eslint ui/src --config ui/eslint.config.js",
    "preview": "vite preview --config ui/vite.config.ts",
    "gen:api": "openapi --input http://127.0.0.1:8000/api/schema/ --output ui/src/gen/api --client fetch --useUnionTypes",
    "gen:api:clean": "rm -rf ui/src/gen/api",
    "gen:api:refresh": "npm run gen:api:clean && npm run gen:api"
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.90.21",
    "alpinejs": "^3.15.8",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "htmx.org": "^2.0.8",
    "i18next": "^25.8.5",
    "lucide": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
