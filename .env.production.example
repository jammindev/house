# ─── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
# Générer avec : openssl rand -base64 50
SECRET_KEY=change-me-generate-with-openssl-rand-base64-50
DEBUG=False
ALLOWED_HOSTS=house.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://house.yourdomain.com
CORS_ALLOWED_ORIGINS=https://house.yourdomain.com

# ─── Database ──────────────────────────────────────────────────────────────────
# "db" = nom du service Docker défini dans docker-compose.prod.yml
DATABASE_URL=postgres://house_user:POSTGRES_PASSWORD@db:5432/house
POSTGRES_PASSWORD=change-me-strong-password

# ─── Sécurité ──────────────────────────────────────────────────────────────────
# Traefik gère le TLS en amont — USE_X_FORWARDED_PROTO permet à Django de
# reconnaître les requêtes comme HTTPS malgré la communication interne en HTTP
SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_PROTO=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ─── Traefik ───────────────────────────────────────────────────────────────────
DOMAIN=house.yourdomain.com
