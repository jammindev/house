{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./ui/src/*"],
      "@apps/*": ["./apps/*"]
    }
  },
  "include": [
    "ui/src/**/*",
    "apps/**/*.ts",
    "apps/**/*.tsx"
  ]
}
